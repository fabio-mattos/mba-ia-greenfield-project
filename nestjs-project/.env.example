# Application
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DB_HOST=db
DB_PORT=5432
DB_USERNAME=streamtube
DB_PASSWORD=streamtube
DB_NAME=streamtube

# JWT
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
CONFIRMATION_TOKEN_EXPIRATION_HOURS=1
PASSWORD_RESET_TOKEN_EXPIRATION_HOURS=1

# Mail (Mailpit for local development)
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM="StreamTube" <noreply@streamtube.com>

# Object Storage (MinIO for local development)
STORAGE_HOST=minio
STORAGE_PORT=9000
STORAGE_USE_SSL=false
STORAGE_ACCESS_KEY_ID=streamtube
STORAGE_SECRET_ACCESS_KEY=streamtube123
STORAGE_BUCKET=streamtube
STORAGE_REGION=us-east-1

# Queue (Redis for local development)
QUEUE_REDIS_HOST=redis
QUEUE_REDIS_PORT=6379
