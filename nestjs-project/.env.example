NODE_ENV=development
PORT=3000
# URL pública da aplicação (usada para links em e-mails, etc.)
APP_URL=http://localhost:3000

# PostgreSQL — use o nome do serviço Docker como host
DB_HOST=db
DB_PORT=5432
DB_USERNAME=streamtube
DB_PASSWORD=streamtube
DB_NAME=streamtube

# JWT — troque os valores em produção
JWT_SECRET=troque-este-segredo-em-producao
JWT_REFRESH_SECRET=troque-este-refresh-segredo-em-producao
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
CONFIRMATION_TOKEN_EXPIRATION_HOURS=1
PASSWORD_RESET_TOKEN_EXPIRATION_HOURS=1

# SMTP (Mailpit em dev, SMTP real em produção)
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM=noreply@streamtube.local

# MinIO / S3 — use o nome do serviço Docker como endpoint
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=streamtube
MINIO_SECRET_KEY=streamtube123
MINIO_USE_SSL=false
MINIO_BUCKET_VIDEOS=videos
MINIO_BUCKET_THUMBNAILS=thumbnails
MINIO_PRESIGNED_UPLOAD_TTL=7200
MINIO_PRESIGNED_STREAM_TTL=21600

# Redis (BullMQ)
REDIS_HOST=redis
REDIS_PORT=6379

# Swagger UI (desabilite em produção)
SWAGGER_ENABLED=true
