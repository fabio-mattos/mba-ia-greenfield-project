# Copie este arquivo para .env.production e substitua TODOS os valores de
# exemplo por segredos reais antes de subir docker-compose.prod.yml de verdade.
# .env.production nunca deve ser commitado (já está no .gitignore).

# --- nestjs-api ---
NODE_ENV=production
PORT=3000
APP_URL=http://localhost:3000

DB_HOST=db
DB_PORT=5432
DB_USERNAME=streamtube
DB_PASSWORD=troque-esta-senha
DB_NAME=streamtube

JWT_SECRET=troque-este-segredo-em-producao
JWT_REFRESH_SECRET=troque-este-outro-segredo-em-producao
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
CONFIRMATION_TOKEN_EXPIRATION_HOURS=1
PASSWORD_RESET_TOKEN_EXPIRATION_HOURS=1

MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM=noreply@streamtube.local

MINIO_ENDPOINT=minio
MINIO_PORT=9000
# MINIO_ACCESS_KEY/MINIO_SECRET_KEY (usados pelo nestjs-api e video-worker como
# clientes) DEVEM ser idênticos a MINIO_ROOT_USER/MINIO_ROOT_PASSWORD abaixo
# (usados pelo próprio container do MinIO) — são a mesma credencial.
MINIO_ACCESS_KEY=streamtube
MINIO_SECRET_KEY=troque-esta-senha-minio
MINIO_USE_SSL=false
MINIO_BUCKET_VIDEOS=videos
MINIO_BUCKET_THUMBNAILS=thumbnails
MINIO_PRESIGNED_UPLOAD_TTL=7200
MINIO_PRESIGNED_STREAM_TTL=21600

REDIS_HOST=redis
REDIS_PORT=6379

SWAGGER_ENABLED=false

# --- MinIO root credentials (usadas pelo próprio container do MinIO — devem
# bater com MINIO_ACCESS_KEY/MINIO_SECRET_KEY acima) ---
MINIO_ROOT_USER=streamtube
MINIO_ROOT_PASSWORD=troque-esta-senha-minio

# --- next-frontend ---
# Nome do serviço na rede Docker deste compose (não host.docker.internal —
# isso só é necessário quando os stacks de dev rodam separados).
API_URL=http://nestjs-api:3000
SESSION_PASSWORD=troque-esta-senha-com-pelo-menos-32-caracteres
